# Environment mode ("DEV" enables CORS, dev user fallback, debug info)
ENV=DEV

# ── Databricks Authentication ──────────────────────────────────────────
# Option 1: Personal access token
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=

# Option 2: Service principal (OAuth M2M)
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# ── SQL Warehouse ──────────────────────────────────────────────────────
# Provide either the warehouse ID or the full HTTP path
DATABRICKS_SQL_WAREHOUSE_ID=
# DATABRICKS_WAREHOUSE_PATH=/sql/1.0/warehouses/<id>

# ── Unity Catalog ──────────────────────────────────────────────────────
LAKEHOUSE_CATALOG_NAME=
LAKEHOUSE_SCHEMA_NAME=

# ── Lakebase (PostgreSQL) ─────────────────────────────────────────────
# When running on Databricks Apps these are injected automatically.
# For local development, set them manually.
PGHOST=
PGDATABASE=
PGUSER=
PGPORT=5432
PGSSLMODE=require
# PGAPPNAME=
# LAKEBASE_CATALOG_NAME=
# LAKEBASE_SCHEMA=app

# ── Database Pool (optional) ──────────────────────────────────────────
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_COMMAND_TIMEOUT=30
# DB_POOL_TIMEOUT=10
# DB_POOL_RECYCLE_INTERVAL=3600

# ── Model Serving (optional) ──────────────────────────────────────────
# AI agent endpoint for template assistance
# MODEL_SERVING_ENDPOINT=databricks-claude-sonnet-4-6
